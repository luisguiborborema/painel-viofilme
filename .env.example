# ============================================================================
# PAINEL VIOFILME — variáveis de ambiente
# Copie para .env.local e preencha. Sem isto, o painel roda em MODO DEMO.
# ============================================================================

# --- Supabase (autenticação + banco) ---------------------------------------
# Encontre em: app.supabase.com → seu projeto → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Chave de serviço (somente no servidor — NUNCA exponha no cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Meta Graph API (Instagram + Facebook) ---------------------------------
# Crie um app em https://developers.facebook.com/ (tipo "Business")
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# URL pública do app (usada no redirect do OAuth da Meta)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Versão da Graph API
META_GRAPH_VERSION=v21.0

# --- IA (Bruna + insights automáticos via Claude) --------------------------
# Usada apenas no servidor (rotas /api/chat e /api/insights). Sem ela, a Bruna
# e os blocos de insight caem no fallback (modo demonstração).
ANTHROPIC_API_KEY=sk-ant-...

# --- Sincronização Meta → Supabase (cron) ----------------------------------
# Segredo que protege a rota /api/meta/sync. O Vercel Cron envia
# "Authorization: Bearer <CRON_SECRET>" na chamada agendada (vercel.json).
# Gere um valor aleatório forte (ex.: `openssl rand -hex 32`).
CRON_SECRET=troque-por-um-valor-aleatorio-forte
